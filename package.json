{
  "name": "k12-lms-platform",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "phase11:build": "node tools/simulation/phase11/build-phase11.mjs",
    "phase11:audit": "node tools/simulation/phase11/audit-phase11.mjs",
    "phase11:test": "node --test tools/simulation/phase11/*.test.mjs"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "bash -c 'cd apps/web && npx eslint --fix \"$@\"' --",
      "bash -c 'cd apps/web && npx prettier --write \"$@\"' --"
    ],
    "apps/web/**/*.{json,md,css}": [
      "bash -c 'cd apps/web && npx prettier --write \"$@\"' --"
    ]
  }
}
