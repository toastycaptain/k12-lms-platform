{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://k12lms.local/contracts/curriculum-pack-vnext.schema.json",
  "title": "Curriculum Pack Capability Schema VNext",
  "type": "object",
  "required": [
    "schema_version",
    "pack",
    "primitives",
    "capabilities",
    "backward_compatibility",
    "source"
  ],
  "properties": {
    "schema_version": {
      "const": "curriculum_pack_vnext.v1"
    },
    "pack": {
      "type": "object",
      "required": ["key", "version", "label"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 }
      }
    },
    "primitives": {
      "type": "object",
      "required": ["shared", "ib_specific"],
      "properties": {
        "shared": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ib_specific": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "required": [
        "documents",
        "workflows",
        "reporting",
        "publishing",
        "migration",
        "governance",
        "navigation"
      ],
      "properties": {
        "documents": {
          "type": "object",
          "required": ["template_catalog", "schema_count"],
          "properties": {
            "template_catalog": {
              "type": "array",
              "items": { "type": "object" }
            },
            "schema_count": { "type": "integer", "minimum": 0 }
          }
        },
        "workflows": {
          "type": "object",
          "required": ["templates", "bindings"],
          "properties": {
            "templates": {
              "type": "array",
              "items": { "type": "object" }
            },
            "bindings": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "reporting": {
          "type": "object",
          "required": ["engine_key", "render_hooks", "report_bindings"],
          "properties": {
            "engine_key": { "type": "string" },
            "render_hooks": {
              "type": "array",
              "items": { "type": "string" }
            },
            "report_bindings": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "publishing": {
          "type": "object",
          "required": ["engine_key", "supports_evidence_capture", "supports_story_composition", "supports_family_delivery"],
          "properties": {
            "engine_key": { "type": "string" },
            "supports_evidence_capture": { "type": "boolean" },
            "supports_story_composition": { "type": "boolean" },
            "supports_family_delivery": { "type": "boolean" }
          }
        },
        "migration": {
          "type": "object",
          "required": ["shared_manifest", "connectors"],
          "properties": {
            "shared_manifest": { "type": "object" },
            "connectors": {
              "type": "object",
              "additionalProperties": { "type": "object" }
            }
          }
        },
        "governance": {
          "type": "object",
          "required": ["engine_key", "consoles"],
          "properties": {
            "engine_key": { "type": "string" },
            "consoles": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        },
        "navigation": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "backward_compatibility": {
      "type": "object",
      "required": [
        "legacy_schema_version",
        "compatibility",
        "preserves_ib_routes",
        "preserves_ib_workflows"
      ],
      "properties": {
        "legacy_schema_version": { "type": "string" },
        "compatibility": { "type": "string" },
        "preserves_ib_routes": { "type": "boolean" },
        "preserves_ib_workflows": { "type": "boolean" }
      }
    },
    "source": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
